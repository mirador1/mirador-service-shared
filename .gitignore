# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/

# Logs
*.log

# Local secrets (never commit OVH/GCP creds)
.env
.env.local
*.pem
*.key
service-account-*.json

# Local Claude Code worktrees + agent state — never committed.
.claude/

# Terraform local cache + state backups (never commit)
deploy/terraform/*/.terraform/
deploy/terraform/*/terraform.tfstate
deploy/terraform/*/terraform.tfstate.backup
deploy/terraform/*/.terraform.lock.hcl
